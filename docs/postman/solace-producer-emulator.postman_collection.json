								"v1",
								"messages",
								"{{messageId}}",
								"retry"
							]
						}
					},
					"response": []
				},
				{
					"name": "retry multiple failed messages",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"messageIds\": [1, 2]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/messages/retry",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"messages",
								"retry"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "reconciliation",
			"item": [
