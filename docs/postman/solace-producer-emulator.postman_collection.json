								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/messages/{{messageId}}/reconcile-stale-pending",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"messages",
								"{{messageId}}",
								"reconcile-stale-pending"
							]
						}
					},
					"response": []
